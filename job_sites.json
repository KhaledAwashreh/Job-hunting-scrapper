  "_add_new_country": {
    "instructions": "Add country under 'countries' with ISO code as key",
    "example": {
      "countrycode": {
        "name": "Country Name",
        "sites": [
          {
            "id": "uniquesiteid",
            "name": "Display Name",
            "base_url": "https://example.com",
            "search_url": "https://example.com/jobs?keywords={keywords}&location={location}",
            "selectors": {
              "job_card": ".job-class",
              "title": ".title-class",
              "company": ".company-class",
              "location": ".location-class",
              "url": "a.link",
              "url_attr": "href"
            },
            "requires_browser": true,
            "rate_limit_ms": 1500
          }
        ]
      }
    }
