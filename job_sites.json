{
  "_meta": {
    "version": "1.0.0",
    "description": "Repository of job/career sites by country",
    "maintainer": "RefNet"
  },
  "global": {
    "description": "Major job boards available in most countries",
    "sites": [
      {
        "id": "linkedin",
        "name": "LinkedIn Jobs",
        "base_url": "https://www.linkedin.com/jobs-guest/jobs/api/seeMoreJobPostings/search",
        "search_params": {
          "keywords": "keywords",
          "location": "location",
          "start": "start"
        },
        "selectors": {
          "job_card": ".job-search-card",
          "title": ".job-search-card__title",
          "company": ".job-search-card__subtitle",
          "location": ".job-search-card__metadata",
          "url": "data-job-url"
        },
        "requires_browser": true,
        "rate_limit_ms": 1000
      },
      {
        "id": "indeed",
        "name": "Indeed",
        "base_url": "https://www.indeed.com/jobs",
        "search_params": {
          "q": "keywords",
          "l": "location",
          "start": "start"
        },
        "selectors": {
          "job_card": ".jobsearch-ResultsList > li > div",
          "title": "h2.jobTitle > a, a.jobtitle",
          "company": ".companyName",
          "location": ".companyLocation",
          "salary": ".salary-snippet, .estimated-salary"
        },
        "requires_browser": false,
        "rate_limit_ms": 1000
      },
      {
        "id": "glassdoor",
        "name": "Glassdoor",
        "base_url": "https://www.glassdoor.com/Job/jobs.htm",
        "search_params": {
          "sc.keyword": "keywords",
          "locT": "C"
        },
        "selectors": {
          "job_card": ".jobHeader",
          "title": ".jobTitle",
          "company": ".employerName"
        },
        "requires_browser": true,
        "rate_limit_ms": 2000
      }
    ]
  },
