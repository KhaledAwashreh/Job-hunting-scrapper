# Ollama Configuration
# Make sure Ollama is running: ollama serve
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=devstral

# Optional: Custom job search keywords (can also pass via CLI)
# DEFAULT_KEYWORDS=software engineer

# Optional: Default countries to search
# DEFAULT_COUNTRIES=Ireland,Spain,Netherlands

# Optional: Proxy settings for scraping
# HTTP_PROXY=
# HTTPS_PROXY=
